generator client {
  provider = "prisma-client-js"

  output = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  email String @unique

  name String?

  password String?

  role Role @default(USER)

  avatar String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  accounts Account[]

  sessions Session[]

  sponsorProposals SponsorProposal[]

  artistApplication ArtistApplication?
}

enum Role {
  ADMIN

  BRAND

  USER

  ARTIST_APPLICANT
}

model Account {
  id String @id @default(cuid())

  userId String

  type String

  provider String

  providerAccountId String

  refresh_token String?

  access_token String?

  expires_at Int?

  token_type String?

  scope String?

  id_token String?

  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id String @id @default(cuid())

  sessionToken String @unique

  userId String

  expires DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String

  token String @unique

  expires DateTime

  @@unique([identifier, token])
}

model Artist {
  id String @id @default(cuid())

  slug String @unique

  name String

  bio_fr String?

  bio_en String?

  shortBio_fr String?

  shortBio_en String?

  avatar String?

  banner String?

  instagram String?

  spotify String?

  soundcloud String?

  youtube String?

  appleMusic String?

  deezer String?

  tiktok String?

  isActive Boolean @default(true)

  order Int @default(0)

  events EventArtist[]

  tracks Track[]

  createdAt DateTime @default(now())
}

model Event {
  id String @id @default(cuid())

  slug String @unique

  title_fr String

  title_en String

  venue String

  city String

  country String @default("France")

  date DateTime

  endDate DateTime?

  description_fr String?

  description_en String?

  ticketUrl String?

  eventUrl String?

  photos String?

  isB2B Boolean @default(false)

  isFeatured Boolean @default(false)

  isActive Boolean @default(true)

  artists EventArtist[]

  createdAt DateTime @default(now())
}

model EventArtist {
  eventId String

  artistId String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([eventId, artistId])
}

model Track {
  id String @id @default(cuid())

  title String

  artistName String

  soundcloudEmbedUrl String?

  spotifyEmbedUrl String?

  youtubeEmbedUrl String?

  externalUrl String?

  cover String?

  isActive Boolean @default(true)

  order Int @default(0)

  artistId String?

  artist Artist? @relation(fields: [artistId], references: [id])

  releasedAt DateTime?

  createdAt DateTime @default(now())
}

model Video {
  id String @id @default(cuid())

  title String

  youtubeEmbedUrl String

  thumbnail String?

  isActive Boolean @default(true)

  order Int @default(0)

  createdAt DateTime @default(now())
}

model SponsorProposal {
  id              String         @id @default(cuid())
  userId          String?
  brandName       String
  contactName     String?
  contactEmail    String
  phone           String?
  website         String?
  source          String?
  campaignType    String?
  description     String
  budget          String?
  expectedAmount  Float?
  paidAmount      Float?
  currency        String         @default("EUR")
  status          ProposalStatus @default(PENDING)
  priority        CrmPriority    @default(NORMAL)
  assignedTo      String?
  nextAction      String?
  nextActionAt    DateTime?
  lastContactAt   DateTime?
  startDate       DateTime?
  endDate         DateTime?
  deliverables    String?
  requiredAssets  String?
  pressKitUrl     String?
  boardUrl        String?
  contractUrl     String?
  invoiceUrl      String?
  promoCode       String?
  adminNote       String?
  amount          Float?
  stripePaymentId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User?          @relation(fields: [userId], references: [id])
  campaigns       Campaign[]
  activities      CrmActivity[]

  @@index([status])
  @@index([nextActionAt])
}

enum ProposalStatus {
  PENDING
  REVIEWING
  CONTACTED
  NEGOTIATING
  VALIDATED
  ACTIVE
  COMPLETED
  REJECTED
  ARCHIVED
}

enum CrmPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Campaign {
  id             String           @id @default(cuid())
  proposalId     String?
  name           String
  brandName      String
  contactName    String?
  contactEmail   String?
  phone          String?
  status         CampaignStatus   @default(DRAFT)
  priority       CrmPriority      @default(NORMAL)
  budget         Float?
  paidAmount     Float?
  currency       String           @default("EUR")
  startDate      DateTime?
  endDate        DateTime?
  nextAction     String?
  nextActionAt   DateTime?
  deliverables   String?
  requiredAssets String?
  pressKitUrl    String?
  boardUrl       String?
  contractUrl    String?
  invoiceUrl     String?
  promoCode      String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  proposal       SponsorProposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  activities     CrmActivity[]

  @@index([status])
  @@index([nextActionAt])
}

enum CampaignStatus {
  DRAFT
  PLANNED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model PrivateBooking {
  id             String        @id @default(cuid())
  title          String
  artistName     String?
  eventType      String?
  venue          String?
  city           String?
  country        String?
  eventDate      DateTime?
  contactName    String
  company        String?
  contactEmail   String?
  phone          String?
  status         BookingStatus @default(NEW)
  priority       CrmPriority   @default(NORMAL)
  budget         Float?
  fee            Float?
  deposit        Float?
  currency       String        @default("EUR")
  source         String?
  nextAction     String?
  nextActionAt   DateTime?
  lastContactAt  DateTime?
  requirements   String?
  requiredAssets String?
  pressKitUrl    String?
  contractUrl    String?
  invoiceUrl     String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  activities     CrmActivity[]

  @@index([status])
  @@index([eventDate])
  @@index([nextActionAt])
}

enum BookingStatus {
  NEW
  QUALIFYING
  CONTACTED
  OPTION
  NEGOTIATING
  CONFIRMED
  DEPOSIT_PAID
  COMPLETED
  CANCELLED
  LOST
}

model CrmActivity {
  id         String           @id @default(cuid())
  proposalId String?
  campaignId String?
  bookingId  String?
  type       CrmActivityType  @default(NOTE)
  title      String
  details    String?
  dueAt      DateTime?
  completed  Boolean          @default(false)
  createdAt  DateTime         @default(now())
  proposal   SponsorProposal? @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  campaign   Campaign?        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  booking    PrivateBooking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([dueAt])
}

enum CrmActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  STATUS_CHANGE
  PAYMENT
  DOCUMENT
}

model ArtistApplication {
  id            String            @id @default(cuid())
  userId        String?           @unique
  name          String
  realName      String?
  email         String
  phone         String?
  city          String?
  country       String?
  bio           String
  genres        String
  soundLinks    String
  socialLinks   String
  pressKitUrl   String?
  portfolioUrl  String?
  stageName     String?
  experience    String?
  availability  String?
  expectations  String?
  status        ApplicationStatus @default(PENDING)
  priority      CrmPriority       @default(NORMAL)
  assignedTo    String?
  nextAction    String?
  nextActionAt  DateTime?
  lastContactAt DateTime?
  adminNote     String?
  rating        Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User?             @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([nextActionAt])
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  CONTACTED
  AUDITION
  ACCEPTED
  REJECTED
  ARCHIVED
}

model NewsletterSubscriber {
  id String @id @default(cuid())

  email String @unique

  name String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
}

model Contact {
  id String @id @default(cuid())

  name String

  email String

  subject String

  message String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  locale    String?
  referrer  String?
  userAgent String?
  sessionId String?
  ipHash    String?
  country   String?
  city      String?
  device    String?
  browser   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([sessionId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  path      String
  label     String?
  target    String?
  locale    String?
  referrer  String?
  sessionId String?
  ipHash    String?
  country   String?
  city      String?
  device    String?
  browser   String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([path])
}

enum InvoiceType {
  ARTIST
  SPONSOR
}

enum InvoiceStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  type          InvoiceType
  clientName    String
  clientEmail   String
  clientAddress String?
  clientPhone   String?
  prestation    String
  priceHT       Float
  tvaRate       Float         @default(20)
  priceTTC      Float
  invoiceDate   DateTime      @default(now())
  status        InvoiceStatus @default(PENDING_PAYMENT)
  sentAt        DateTime?
  paidAt        DateTime?
  artistId      String?
  sponsorId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}
